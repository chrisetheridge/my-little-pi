{
  "name": "my-little-pi",
  "version": "0.1.0",
  "description": "Personal Pi package for extensions, skills, prompts, and themes.",
  "type": "module",
  "private": true,
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "pi-prompt",
    "pi-theme"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run"
  },
  "files": [
    "extensions",
    "skills",
    "prompts",
    "themes",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions/downtime/index.ts",
      "./extensions/little-footer/index.ts",
      "./extensions/little-renderer/index.ts",
      "./extensions/review/index.ts",
      "./extensions/little-spinner/index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-agent-core": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@mariozechner/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mariozechner/pi-agent-core": "latest",
    "@mariozechner/pi-coding-agent": "latest",
    "@mariozechner/pi-tui": "latest",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "typebox": "latest",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.11.0+sha1.4048eeefd564ff1ab248fac3e2854d38245fe2f1",
  "dependencies": {
    "pi-extension-websearch": "file:../pi-extension-websearch"
  }
}
