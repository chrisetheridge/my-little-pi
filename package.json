{
  "name": "my-little-pi",
  "version": "0.1.0",
  "description": "Personal Pi package for extensions, skills, prompts, and themes.",
  "type": "module",
  "private": true,
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "pi-prompt",
    "pi-theme"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run"
  },
  "files": [
    "extensions",
    "skills",
    "prompts",
    "themes",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "latest",
    "typescript": "^5.9.3",
    "typebox": "latest",
    "vitest": "^4.1.5"
  }
}
