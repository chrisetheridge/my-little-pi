{
  "name": "my-little-pi",
  "version": "0.1.0",
  "description": "Personal Pi package for extensions, skills, and themes.",
  "type": "module",
  "private": true,
  "imports": {
    "#extensions/*": "./extensions/*"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "pi-theme"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run",
    "ci": "pnpm run check && pnpm run test && pnpm run pack:dry-run",
    "prepare": "husky"
  },
  "files": [
    "extensions",
    "skills",
    "themes",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions/downtime/index.ts",
      "./extensions/little-footer/index.ts",
      "./extensions/little-renderer/index.ts",
      "./extensions/little-spinner/index.ts",
      "./extensions/session-changes/index.ts",
      "./extensions/startup-screen/index.ts",
      "./extensions/land/index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "themes": [
      "./themes"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-agent-core": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@mariozechner/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@eslint/js": "^10.0.1",
    "@mariozechner/pi-agent-core": "latest",
    "@mariozechner/pi-coding-agent": "latest",
    "@mariozechner/pi-tui": "latest",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^17.0.5",
    "typebox": "latest",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.11.0+sha1.4048eeefd564ff1ab248fac3e2854d38245fe2f1"
}
